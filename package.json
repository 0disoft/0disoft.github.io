{
  "name": "0disoft.github.io",
  "version": "0.0.7",
  "private": true,
  "license": "0BSD",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:index": "bun run paraglide && bun run build && bun run index",
    "preview": "vite preview",
    "index": "bun scripts/pagefind-index.mjs",
    "prepare": "svelte-kit sync || echo ''",
    "check": "bun run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bun run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --strategy url cookie globalVariable baseLocale",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck:fast": "bun run paraglide && tsgo --noEmit"
  },
  "dependencies": {
    "mode-watcher": "^1.1.0"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@inlang/paraglide-js": "^2.20.2",
    "@inlang/plugin-m-function-matcher": "2.2.6",
    "@inlang/plugin-message-format": "4.4.0",
    "@lucide/svelte": "^1.23.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^25.9.5",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "clsx": "^2.1.1",
    "mdsvex": "^0.12.7",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.73.0",
    "pagefind": "^1.5.2",
    "shadcn-svelte": "^1.4.0",
    "shiki": "^3.23.0",
    "simple-icons": "16.18.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
